# Auto detect text files and normalize line endings to LF
* text=auto

# Java
*.java text eol=lf
*.class binary
*.jar binary
*.war binary

# Gradle
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradlew text eol=lf
gradlew.bat text eol=crlf

# Properties
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.exe binary
